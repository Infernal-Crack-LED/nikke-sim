{
  "name": "nikke-sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx src/data/sync.ts && tsx scripts/build-archetype-tags.ts --write",
    "sync:skills": "tsx src/data/sync-skill-levels.ts",
    "sim": "tsx src/cli.ts",
    "web": "vite",
    "dpschart": "tsx scripts/build-dpschart.ts",
    "thumbs": "tsx scripts/gen-portrait-thumbs.ts",
    "meta-weights": "tsx scripts/build-meta-weights.ts",
    "ui-shot": "node scripts/ui-shot.mjs",
    "web:build": "vite build && node scripts/prerender.mjs",
    "web:preview": "vite preview",
    "build": "vite build && node scripts/prerender.mjs",
    "build:deploy": "npm run dpschart && npm run build",
    "start": "node scripts/serve.mjs",
    "typecheck": "tsc -p web/tsconfig.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "npm run web:build && node scripts/web-smoke.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:dpschart": "npm run dpschart && npm run build && node scripts/web-smoke-dpschart.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
